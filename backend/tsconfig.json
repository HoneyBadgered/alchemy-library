{
  "extends": "@strapi/typescript-utils/tsconfigs/server",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmitOnError": false
  },
  "include": ["./", "./**/*.ts", "./**/*.js", "./**/*.json"],
  "exclude": ["node_modules", "build", ".cache", "dist", ".tmp"]
}
